    "nestedCallerRoleArn": "arn:aws:iam::253490756794:role/disc-fsa-prod-stepfunction-nestedcaller-servicerole"
  },
  "LambdaConfig": [
    {
      "Job-Logging-End": {
        "runtime": "python3.10",
        "timeoutSeconds": 120,
        "memoryMb": 256,
        "layers": [
          "arn:aws:lambda:us-east-1:253490756794:layer:FSA_DEV-psycopg2:1"
        ],
        "networking": {
          "vpcId": "vpc-092b2aee3fba9e5e6",
          "subnetIds": [
            "subnet-0d4691e36b391b17f"
          ],
          "securityGroupIds": [
            "sg-05e3e3fd000913769"
          ]
        },
        "environmentVariables": {
          "SecretId": "FSA-PROD-secrets",
          "CRAWLER_NAME": "FSA-PROD-CPS",
          "LAST_COMPLETE_TARGET": "FSA-PROD-CPS"
        }
      }
    },
    {
      "RAW-DM-etl-workflow-update": {
        "runtime": "python3.10",
        "timeoutSeconds": 120,
        "memoryMb": 256,
        "layers": [
          "arn:aws:lambda:us-east-1:253490756794:layer:FSA_DEV-psycopg2:1"
        ],
        "environmentVariables": {
          "SecretId": "FSA-PROD-secrets",
          "LAST_COMPLETE_TARGET": "FSA-PROD-CPS",
          "STEP2_NAME": "FSA-PROD-CPS-S3Landing-to-S3Final-Raw-DM"
        },
        "networking": {
          "vpcId": "vpc-092b2aee3fba9e5e6",
          "subnetIds": [
            "subnet-0d4691e36b391b17f"
          ],
          "securityGroupIds": [
            "sg-05e3e3fd000913769"
          ]
        }
      }
    },
    {
      "RAW-DM-sns-pub-step-func-errs": {
        "runtime": "python3.10",
        "timeoutSeconds": 120,
        "memoryMb": 256,
        "layers": [],
        "environmentVariables": {
          "SNS_ARN": "arn:aws:sns:us-east-1:253490756794:FSA-PROD-CPS",
          "SNS_SUBJECT": "FSA-PROD-CPS-RAW-DM-NOTIFICATIONS",
          "STATE_MACHINE_NAME": "FSA-PROD-CPS-S3Landing-to-S3Final-Raw-DM"
        }
      }
    },
    {
      "get-incremental-tables": {
        "runtime": "python3.10",
        "timeoutSeconds": 120,
        "memoryMb": 256,
        "layers": [],
        "networking": {
          "vpcId": "vpc-092b2aee3fba9e5e6",
          "subnetIds": [
            "subnet-0d4691e36b391b17f"
          ],
          "securityGroupIds": [
            "sg-05e3e3fd000913769"
          ]
        },
        "environmentVariables": {
          "source_folder": "cps",
          "LANDING_BUCKET": "c108-prod-fpacfsa-landing-zone"
        }
      }
    },
    {
      "sns-publish-validations-report": {
        "runtime": "python3.10",
        "timeoutSeconds": 120,
        "memoryMb": 256,
        "layers": [],
        "environmentVariables": {
          "SNS_ARN": "arn:aws:sns:us-east-1:253490756794:FSA-PROD-CPS",
          "REPORT_ENV_LABEL": "PROD"
        }
      }
    },
    {
      "validation-check": {
        "runtime": "python3.10",
        "timeoutSeconds": 120,
        "memoryMb": 256,
        "layers": [
          "arn:aws:lambda:us-east-1:253490756794:layer:FSA_DEV-psycopg2:1"
        ],
        "networking": {
          "vpcId": "vpc-092b2aee3fba9e5e6",
          "subnetIds": [
            "subnet-0d4691e36b391b17f"
          ],
          "securityGroupIds": [
            "sg-05e3e3fd000913769"
          ]
        },
        "environmentVariables": {
          "SecretId": "FSA-PROD-secrets",
          "CRAWLER_NAME": "FSA-PROD-CPS"
        }
      }
    }
  ],
  "configUpload": {
    "functionName": "FSA-PROD-UploadConfig",
    "sourceDir": "configs",
    "inputBucket": "fsa-prod-ops",
    "inputPrefix": "input/zips",
    "outputBucket": "c108-prod-fpacfsa-final-zone",
    "outputPrefix": "cps",
    "minExpectedObjects": 1,
    "debug": true
  },
  "GlueConfig": [
    {
      "LandingFiles": {
        "Connections": [{ "ConnectionName": "FSA-PROD-PG-DART115" }],
        "MaxConcurrency": "1",
        "MaxRetries": "0",
        "TimeoutMinutes": "2880",
        "WorkerType": "G.2X",
        "SparkUILogsPath": "s3://fsa-prod-ops/glue-logs/spark-ui/cps/",
        "NumberOfWorkers": "2",
        "AutomaticScalingEnabled": "true",
        "GlueVersion": "4.0",
        "JobLanguage": "python",
        "GenerateMetrics": "true",
        "EnableJobBookmarks": "false",
        "JobObservabilityMetrics": "ENABLED",
        "JobContinuousLogging": "ENABLED",
        "TemporaryPath": "s3://fsa-prod-ops/temp/glue/",
        "PythonLibraryPath": "",
        "ReferencePath": "s3://c108-prod-fpacfsa-landing-zone/dart/scripts/python-modules/glue/psycopg2_binary-2.9.9-cp310-cp310-manylinux_2_17_x86_64.manylinux2014_x86_64.whl",
        "AdditionalPythonModulesPath": "s3://c108-prod-fpacfsa-landing-zone/dart/scripts/python-modules/glue/psycopg2_binary-2.9.9-cp310-cp310-manylinux_2_17_x86_64.manylinux2014_x86_64.whl",
        "UseGlueDataCatalogAsTheHiveMetastore": "true",
        "JobParameters": {
          "--DestinationBucket": "c108-prod-fpacfsa-landing-zone",
          "--DestinationPrefix": "cps/etl-jobs",
          "--PipelineName": "cps",
          "--SecretId": "FSA-PROD-secrets",
          "--SourcePrefix": "cps/dbo",
          "--Config_key": "cps/_configs/cps_target_schema.json"
        }
      }
    },       
    {
      "Raw-DM": {
        "Connections": [{ "ConnectionName": "FSA-PROD-PG-DART115" }],
        "MaxConcurrency": "20",
        "MaxRetries": "0",
        "TimeoutMinutes": "600",
        "WorkerType": "G.2X",
        "SparkUILogsPath": "s3://fsa-prod-ops/glue-logs/spark-ui/cps/",
        "NumberOfWorkers": "2",
        "AutomaticScalingEnabled": "true",
        "GlueVersion": "4.0",
        "JobLanguage": "python",
        "GenerateMetrics": "true",
        "EnableJobBookmarks": "false",
        "JobObservabilityMetrics": "ENABLED",
        "JobContinuousLogging": "ENABLED",
        "TemporaryPath": "s3://fsa-prod-ops/temp/glue/",
        "PythonLibraryPath": "",
        "UseGlueDataCatalogAsTheHiveMetastore": "true",
        "JobParameters": {
          "--ENABLE_DQ_METRICS": "true",
          "--JobId": "30741",
          "--SKIP_COUNT_TABLES": "ewt86shloc",
          "--SKIP_DQ_TABLES": "prod",
          "--TableName": "abc",
          "--env": "prod",
          "--postgres_prcs_ctrl_dbname": "metadata_edw",
          "--region_name": "us-east-1",
          "--secret_name": "FSA-PROD-secrets",
          "--source_prefix": "cps",
          "--target_bucket": "c108-prod-fpacfsa-final-zone",
          "--target_prefix": "cps"
        }
      }
    }
    
  ],
  "crawlers": [
    {
      "crawlerName": "FSA-{deployEnv}-{projectName}",
      "description": "cps BASE crawler",
      "databaseName": "fsa-prod-cps",
      "recrawlBehavior": "CRAWL_EVERYTHING",
      "excludePatterns": ["_cdc/**", "_configs/**"],
      "s3TargetsByBucket": [
        {
          "bucket": "c108-prod-fpacfsa-final-zone",
          "prefixes": ["cps/"]
        }
      ]
    },
    {
      "crawlerName": "FSA-{deployEnv}-{projectName}-cdc",
      "description": "cps BASE CDC crawler",
      "databaseName": "fsa-prod-cps-cdc",
      "recrawlBehavior": "CRAWL_EVERYTHING",
      "s3TargetsByBucket": [
        {
          "bucket": "c108-prod-fpacfsa-final-zone",
          "prefixes": ["cps/_cdc/"]
        }
      ]
    }
  ]
}
