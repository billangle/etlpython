  "crawlers": [
    {
      "crawlerName": "FSA-{deployEnv}-{projectName}",
      "description": "dmc crawler data sources (grouped by bucket)",
      "databaseName": "fsa-steamdev-dmc",
      "recrawlBehavior": "CRAWL_EVERYTHING",
      "excludePatterns": ["_cdc/**", "_configs/**"],
      "s3TargetsByBucket": [
        {
          "bucket": "punkdev-fpacfsa-final-zone",
          "prefixes": [
            "dmc/"
          ]
        }
      ]
    },
    {
      "crawlerName": "FSA-{deployEnv}-{projectName}-cdc",
      "description": "dmc crawler data sources (grouped by bucket)",
