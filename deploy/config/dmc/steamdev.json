  "strparams": {
    "landingBucketNameParam": "punkdev-fpacfsa-landing-zone",
    "cleanBucketNameParam": "punkdev-fpacfsa-cleansed-zone",
    "finalBucketNameParam": "punkdev-fpacfsa-final-zone",
    "jobIdKeyParam": "dmc/etl-jobs/job_id.json",
