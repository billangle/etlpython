{
  "deployEnv": "STEAMDEV",
  "project": "DMC",
  "region": "us-east-1",
  "bucketRegion": "us-east-1",
  "secretId": "FSA-DEV-Secrets",

  "configData": {
    "databaseName": "fsa-fpac-db",
    "dynamoTableName": "FsaFpacMetadata"
  },
  "glueDatabases": [
    {
      "name": "fsa-steamdev-dmc",
      "description": "Primary Glue database for dmc"
    },
    {
      "name": "fsa-steamdev-dmc-cdc",
      "description": "CDC Glue database for dmc"
    }
