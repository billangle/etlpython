    "thirdPartyLayerArnParam": "arn:aws:lambda:us-east-1:335965711887:layer:FSA-DEV-MDART-layer:1",
    "customLayerArnParam": "arn:aws:lambda:us-east-1:335965711887:layer:FSA-polars:1",
    "snsArnParam": "arn:aws:sns:us-east-1:335965711887:FSA-DEV-FMMI"
  },
  "paths": {
    "glueRootPath": "glue/",
    "lambdaRootPath": "lambda/"
  },

  "artifacts": {
    "artifactBucket": "dev-cars-artifacts",
    "prefix": "dmc/"
  },

  "stepFunctions": {
    "createRoleIfMissing": false,
    "roleName": "FSA-dev-FPACCARS-SfnExec",
    "roleArn": "arn:aws:iam::335965711887:role/FSA-dev-FPACCARS-SfnExec",
    "nestedCallerRoleArn": "arn:aws:iam::335965711887:role/FSA-dev-FPACCARS-SfnNestedCaller"
  },
  "LambdaConfig": [
    {
      "Job-Logging-End": {
        "runtime": "python3.10",
        "timeoutSeconds": 120,
        "memoryMb": 256,
        "layers": [],
        "environmentVariables": {
          "SecretId": "FSA-DEV-Secrets",
          "CRAWLER_NAME": "FSA-STEAMDEV-DMC",
          "LAST_COMPLETE_TARGET": "FSA-STEAMDEV-DMC"
        }
      }
    },
    {
      "RAW-DM-etl-workflow-update": {
        "runtime": "python3.10",
        "timeoutSeconds": 120,
        "memoryMb": 256,
        "layers": [],
        "environmentVariables": {
          "SecretId": "FSA-DEV-Secrets",
          "LAST_COMPLETE_TARGET": "FSA-STEAMDEV-DMC",
          "STEP2_NAME": "FSA-STEAMDEV-DMC-S3Landing-to-S3Final-Raw-DM"
        }
      }
    },
    {
      "RAW-DM-sns-pub-step-func-errs": {
        "runtime": "python3.10",
        "timeoutSeconds": 120,
        "memoryMb": 256,
        "layers": [],
        "environmentVariables": {
          "SNS_ARN": "arn:aws:sns:us-east-1:335965711887:FSA-DEV-FMMI",
          "SNS_SUBJECT": "FSA-STEAMDEV-DMC-RAW-DM-NOTIFICATIONS",
          "STATE_MACHINE_NAME": "FSA-STEAMDEV-DMC-S3Landing-to-S3Final-Raw-DM"
        }
      }
    },
    {
      "get-incremental-tables": {
        "runtime": "python3.10",
        "timeoutSeconds": 120,
        "memoryMb": 256,
        "layers": [],
        "environmentVariables": {
          "source_folder": "dmc",
          "LANDING_BUCKET": "punkdev-fpacfsa-landing-zone"
        }
      }
    },
    {
      "sns-publish-validations-report": {
        "runtime": "python3.10",
        "timeoutSeconds": 120,
        "memoryMb": 256,
        "layers": [],
        "environmentVariables": {
          "SNS_ARN": "arn:aws:sns:us-east-1:335965711887:FSA-DEV-FMMI",
          "REPORT_ENV_LABEL": "STEAMDEV"
        }
      }
    },
    {
      "validation-check": {
        "runtime": "python3.10",
        "timeoutSeconds": 120,
        "memoryMb": 256,
        "layers": [],
        "environmentVariables": {
          "SecretId": "FSA-DEV-Secrets",
          "CRAWLER_NAME": "FSA-STEAMDEV-DMC"
        }
      }
    }
  ],
