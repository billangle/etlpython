pipeline {
    agent any

    options {
        timestamps()
    }

    parameters {
        string(name: 'eventKey', defaultValue: '', description: 'Bitbucket webhook event key (for example repo:refs_changed)')
        string(name: 'projectKey', defaultValue: '', description: 'Bitbucket URL variable: project.key')
        string(name: 'repoSlug', defaultValue: '', description: 'Bitbucket URL variable: repo.slug')
        string(name: 'branchName', defaultValue: '', description: 'Bitbucket URL variable: repo.ref.branchName')
        text(name: 'postBuffer', defaultValue: '', description: 'Raw webhook POST body if forwarded as a parameter')
        text(name: 'payload', defaultValue: '', description: 'Alternate raw webhook payload parameter name')
    }

    triggers {
        GenericTrigger(
            genericVariables: [
                [key: 'eventKey', value: '$.eventKey'],
                [key: 'projectKey', value: '$.repository.project.key'],
                [key: 'repoSlug', value: '$.repository.slug'],
                [key: 'branchName', value: '$.changes[0].ref.displayId'],
                [key: 'postBuffer', value: '$']
            ],
            causeString: 'Triggered by Bitbucket webhook',
            token: '72305AD4-A19D-462C-9CEB-275E01BDFAFD',
            printContributedVariables: true,
            printPostContent: false,
            silentResponse: true
        )
    }

    stages {
        stage('Capture Webhook Request') {
            steps {
                script {
                    echo 'Bitbucket webhook received by jenkins-test2.'
                    def eventKey = (env.eventKey ?: params.eventKey ?: '').toString()
                    def projectKey = (env.projectKey ?: params.projectKey ?: '').toString()
                    def repoSlug = (env.repoSlug ?: params.repoSlug ?: '').toString()
                    def branchName = (env.branchName ?: params.branchName ?: '').toString()

                    echo "eventKey  : ${eventKey ?: 'N/A'}"
                    echo "projectKey : ${projectKey ?: 'N/A'}"
                    echo "repoSlug   : ${repoSlug ?: 'N/A'}"
                    echo "branchName : ${branchName ?: 'N/A'}"

                    echo 'Received parameter dump:'
                    params.keySet().sort().each { k ->
                        echo "  ${k} = ${params[k]}"
                    }

                    def unresolved = []
                    [eventKey: eventKey, projectKey: projectKey, repoSlug: repoSlug, branchName: branchName].each { k, v ->
                        if (v.startsWith('$')) {
                            unresolved << "${k}=${v}"
                        }
                    }
                    if (unresolved) {
                        echo 'Detected unresolved webhook URL variables:'
                        unresolved.each { echo "  ${it}" }
                        echo 'Use Bitbucket webhook URL variable syntax that your server version supports.'
                    }

                    if (eventKey == 'repo:refs_changed') {
                        echo 'refs_changed event detected. Detailed commit/ref JSON is in webhook POST body, not in eventKey.'
                    }

                    def rawPostBuffer = (env.postBuffer ?: params.postBuffer ?: params.payload ?: env.BITBUCKET_PAYLOAD ?: env.payload ?: '').toString()
                    if (rawPostBuffer.trim()) {
                        echo "POST buffer detected. Length: ${rawPostBuffer.length()} chars"
                        echo 'POST buffer preview (first 4000 chars):'
                        echo rawPostBuffer.take(4000)
                        writeFile file: 'bitbucket-webhook-post-buffer.json', text: rawPostBuffer
                        echo 'Saved POST buffer to bitbucket-webhook-post-buffer.json'
                    } else {
                        echo 'No POST buffer found. Checked params.postBuffer, params.payload, env.BITBUCKET_PAYLOAD, env.payload.'
                    }

                    def captured = [
                        eventKey: eventKey,
                        projectKey: projectKey,
                        repoSlug: repoSlug,
                        branchName: branchName,
                        postBufferPresent: rawPostBuffer.trim() ? true : false,
                        postBufferLength: rawPostBuffer.length()
                    ]
                    writeFile file: 'bitbucket-webhook-url-variables.json', text: groovy.json.JsonOutput.prettyPrint(groovy.json.JsonOutput.toJson(captured))
                    echo 'Saved captured URL variables to bitbucket-webhook-url-variables.json'
                }
            }
        }
    }

    post {
        always {
            archiveArtifacts artifacts: 'bitbucket-webhook-url-variables.json,bitbucket-webhook-post-buffer.json', allowEmptyArchive: true
        }
    }
}
