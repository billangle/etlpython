pipeline {
    agent any

    options {
        timestamps()
    }

    environment {
        WEBHOOK_PAYLOAD_FILE = 'bitbucket-webhook-payload.json'
    }

    triggers {
        GenericTrigger(
            token: 'flpids-bitbucket-webhook-test2',
            causeString: 'Triggered by Bitbucket webhook',
            printContributedVariables: true,
            printPostContent: false,
            genericVariables: [
                [key: 'BB_RAW_PAYLOAD', value: '$'],
                [key: 'BB_EVENT_KEY', value: '$.eventKey'],
                [key: 'BB_DATE', value: '$.date'],
                [key: 'BB_ACTOR', value: '$.actor.displayName'],
                [key: 'BB_REPO', value: '$.repository.fullName'],
                [key: 'BB_PROJECT', value: '$.repository.project.key'],
                [key: 'BB_BRANCH', value: '$.changes[0].ref.displayId'],
                [key: 'BB_COMMIT', value: '$.changes[0].toHash']
            ],
            genericHeaderVariables: [
                [key: 'HDR_X_EVENT_KEY', regexpFilter: ''],
                [key: 'HDR_X_REQUEST_ID', regexpFilter: ''],
                [key: 'HDR_CONTENT_TYPE', regexpFilter: ''],
                [key: 'HDR_USER_AGENT', regexpFilter: '']
            ],
            regexpFilterText: '$BB_EVENT_KEY',
            regexpFilterExpression: '.*'
        )
    }

    stages {
        stage('Capture Webhook Request') {
            steps {
                script {
                    echo 'Bitbucket webhook received by jenkins-test2.'
                    echo "Event Key      : ${env.BB_EVENT_KEY ?: 'N/A'}"
                    echo "Event Date     : ${env.BB_DATE ?: 'N/A'}"
                    echo "Actor          : ${env.BB_ACTOR ?: 'N/A'}"
                    echo "Repository     : ${env.BB_REPO ?: 'N/A'}"
                    echo "Project Key    : ${env.BB_PROJECT ?: 'N/A'}"
                    echo "Branch         : ${env.BB_BRANCH ?: 'N/A'}"
                    echo "Commit         : ${env.BB_COMMIT ?: 'N/A'}"
                    echo "Header X-Event : ${env.HDR_X_EVENT_KEY ?: 'N/A'}"
                    echo "Header Req-Id  : ${env.HDR_X_REQUEST_ID ?: 'N/A'}"
                    echo "Content-Type   : ${env.HDR_CONTENT_TYPE ?: 'N/A'}"
                    echo "User-Agent     : ${env.HDR_USER_AGENT ?: 'N/A'}"

                    if (env.BB_RAW_PAYLOAD?.trim()) {
                        writeFile file: env.WEBHOOK_PAYLOAD_FILE, text: env.BB_RAW_PAYLOAD
                        echo "Saved webhook POST body to ${env.WEBHOOK_PAYLOAD_FILE}."

                        def payload = readJSON text: env.BB_RAW_PAYLOAD
                        if (payload instanceof Map) {
                            def changeCount = payload.changes instanceof List ? payload.changes.size() : 0
                            echo "Parsed payload successfully. Change count: ${changeCount}"
                        }
                    } else {
                        echo 'No POST body payload captured (BB_RAW_PAYLOAD was empty).'
                    }
                }
            }
        }
    }

    post {
        always {
            archiveArtifacts artifacts: 'bitbucket-webhook-payload.json', allowEmptyArchive: true
        }
    }
}
