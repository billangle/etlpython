pipeline {
    agent any

    options {
        timestamps()
    }

    environment {
        WEBHOOK_PAYLOAD_FILE = 'bitbucket-webhook-payload.json'
    }

    triggers {
        bitbucketPush()
    }

    stages {
        stage('Capture Webhook Request') {
            steps {
                script {
                    echo 'Bitbucket webhook received by jenkins-test2.'
                    sh 'printenv | sort | grep -Ei "bitbucket|payload|webhook" || true'

                    def rawPayload = env.BITBUCKET_PAYLOAD ?: env.payload ?: ''
                    if (rawPayload?.trim()) {
                        writeFile file: env.WEBHOOK_PAYLOAD_FILE, text: rawPayload
                        echo "Saved raw webhook POST body to ${env.WEBHOOK_PAYLOAD_FILE}."
                        echo 'Raw webhook payload (first 4000 chars):'
                        echo rawPayload.take(4000)
                    } else {
                        echo 'No raw payload variable was found (checked BITBUCKET_PAYLOAD and payload).'
                        echo 'If needed, expose the POST body in your Jenkins Bitbucket plugin/job config.'
                    }
                }
            }
        }
    }

    post {
        always {
            archiveArtifacts artifacts: 'bitbucket-webhook-payload.json', allowEmptyArchive: true
        }
    }
}
