pipeline {
    agent any

    triggers {
        GenericTrigger(
            genericVariables: [
                [key: 'eventKey', value: '$.eventKey']
            ],
            causeString: 'Triggered by webhook: $eventKey',
            regexpFilterText: '',
            regexpFilterExpression: '',
            printContributedVariables: true,
            printPostContent: true,
            silentResponse: false,
            token: 'bitbucket-echo-debug'
        )
    }

    stages {
        stage('Webhook') {
            steps {
                echo 'Webhook triggered.'
                sh 'echo "eventKey=$eventKey"'
            }
        }
    }
}