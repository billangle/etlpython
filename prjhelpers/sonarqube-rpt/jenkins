pipeline {
    agent any

    environment {
        SONAR_HOST_URL = 'https://sonarqube-dev.dl.usda.gov/sonarqube'
        SONAR_PROJECT_KEY = 'FPAC-WEBEQ-DataPipeline'
        SONAR_BRANCH = 'main'
        SONARQUBE_URL = 'https://sonarqube-dev.dl.usda.gov/sonarqube'
        SONARQUBE_PROJECT_KEY = 'FPAC-WEBEQ-DataPipeline'
        SONARQUBE_TOKEN_NAME='WebAPI-TOKEN'
        SONAR_TOKEN='squ_00b3c770f619f23369b5553615d58d0b3e5e3626'
    }

    stages {
        stage('Clean Workspace') {
            steps {
                cleanWs()
            }
        }
 
        stage('Checkout Code') {
            steps {
                echo 'Checking out code from Bitbucket'
                script {
                    checkout scm: [
                        $class: 'GitSCM',
                        branches: [[name: 'main']],
                        userRemoteConfigs: [[
                            url: 'https://bitbucket.fpac.usda.gov/scm/fsadm/fpac-py-deploy.git', 
                            credentialsId: 'BitBucketRepoAccess'
                        ]]
                    ]
                }
            }
        }

        
        stage('Install') {
            steps {
                sh '''
                cd prjhelpers/sonarqube-rpt;
                python3 -m venv .venv
                . .venv/bin/activate
                pip install -U pip
                pip install -r requirements.txt
                '''
            }
        }

        stage('Generate SonarQube PDF Report') {
            steps {
                withCredentials([string(credentialsId: 'SonarQubeToken', variable: 'SONAR_TOKEN')]) {
                    sh '''
                        cd prjhelpers/sonarqube-rpt;
                        . .venv/bin/activate
                       
                        python3 sonarqube_pdf_report.py \
                          --project-key "$SONAR_PROJECT_KEY" \
                          --branch "$SONAR_BRANCH" \
                          --token "$SONAR_TOKEN" \
                          --host-url "$SONAR_HOST_URL" \
                          --debug-http \
                          --debug-log-file "sonarqube_report_debug.log" \
                          --output sonar-report.pdf
                    '''
                }
            }
            post {
                always {
                    archiveArtifacts artifacts: 'sonar-report.pdf', fingerprint: true
                }
            }
        }
    }
}